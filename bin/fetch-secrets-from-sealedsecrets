#!/usr/bin/env bash
set -euo pipefail

sealed_file="${1:-SealedSecret.yaml}"
out_file="${2:-Secret.yaml}"

if [[ ! -f "$sealed_file" ]]; then
  echo "error: sealed secrets file not found: $sealed_file" >&2
  exit 1
fi

if ! command -v kubectl >/dev/null 2>&1; then
  echo "error: kubectl not found in PATH" >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "error: python3 not found in PATH" >&2
  exit 1
fi

use_kubectl_neat=1
if ! command -v kubectl-neat >/dev/null 2>&1; then
  use_kubectl_neat=0
  echo "warning: kubectl-neat not found in PATH; output will include more generated metadata." >&2
fi

mapfile -t refs < <(
  python3 - "$sealed_file" <<'PY'
import sys
from pathlib import Path

text = Path(sys.argv[1]).read_text()
chunks = [c for c in text.split('---') if c.strip()]
for chunk in chunks:
    lines = chunk.splitlines()
    kind = None
    name = None
    namespace = None
    in_metadata = False
    metadata_indent = None
    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith('#'):
            continue
        indent = len(line) - len(line.lstrip(' '))
        if stripped.startswith('kind:'):
            kind = stripped.split(':', 1)[1].strip()
        if stripped == 'metadata:':
            in_metadata = True
            metadata_indent = indent
            continue
        if in_metadata and indent <= metadata_indent and stripped != 'metadata:':
            in_metadata = False
        if in_metadata:
            if stripped.startswith('name:') and name is None:
                name = stripped.split(':', 1)[1].strip().strip('"\'')
            elif stripped.startswith('namespace:') and namespace is None:
                namespace = stripped.split(':', 1)[1].strip().strip('"\'')
    if kind == 'SealedSecret' and name and namespace:
        print(f"{namespace}\t{name}")
PY
)

if [[ ${#refs[@]} -eq 0 ]]; then
  echo "error: no SealedSecret entries found in $sealed_file" >&2
  exit 1
fi

if [[ -e "$out_file" ]]; then
  echo "warning: $out_file already exists and will be overwritten." >&2
  read -r -p "continue? [y/N] " confirm
  case "$confirm" in
    y|Y|yes|YES)
      ;;
    *)
      echo "aborted." >&2
      exit 1
      ;;
  esac
fi

: > "$out_file"
first=1
for ref in "${refs[@]}"; do
  namespace=${ref%%$'\t'*}
  name=${ref#*$'\t'}

  if [[ $first -eq 0 ]]; then
    printf '\n---\n' >> "$out_file"
  fi
  first=0

  echo "fetching secret/$name from namespace $namespace" >&2
  if [[ $use_kubectl_neat -eq 1 ]]; then
    kubectl get secret "$name" -n "$namespace" -o yaml | kubectl-neat >> "$out_file"
  else
    kubectl get secret "$name" -n "$namespace" -o yaml >> "$out_file"
  fi
done

echo "wrote $out_file" >&2
