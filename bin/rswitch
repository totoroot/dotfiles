#!/usr/bin/env bash
# rswitch — rebuild and switch to NixOS/Darwin configuration
#
# Usage:
#   rswitch [--host HOST] [--force-host] [ACTION] [-- NIX_BUILD_ARGS...]
#
# Actions:
#   switch | test | boot
#
# Examples:
#   rswitch
#   rswitch test
#   rswitch --host myhost switch
#   rswitch -- --show-trace
#   rswitch test -- --cores 0 --show-trace
#
# On Linux/NixOS, rswitch builds `config.system.build.toplevel` directly and
# runs `switch-to-configuration`, avoiding nixos-rebuild-specific evaluation
# issues. On Darwin, it still uses darwin-rebuild.
#
# NIX_BUILD_ARGS after `--` are passed to `nix build` (Linux) or
# `darwin-rebuild` (Darwin).
# Useful flags:
#   --show-trace
#   --cores N
#   --keep-going
#   --fallback

host="$(hostname)"
flake_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
target_host="$host"
force_host=0
args=()
action="switch"
nix_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      shift
      target_host="${1:-}"
      ;;
    --force-host)
      force_host=1
      ;;
    *)
      args+=("$1")
      ;;
  esac
  shift || true
done

if [[ -z "$target_host" ]]; then
  echo "Error: --host requires a value" >&2
  exit 1
fi

if [[ $force_host -ne 1 && "$target_host" != "$host" ]]; then
  echo "Refusing to rebuild: host is $host (expected $target_host)." >&2
  echo "Use --force-host to override." >&2
  exit 1
fi

if [[ ${#args[@]} -gt 0 ]]; then
  case "${args[0]}" in
    switch|test|boot)
      action="${args[0]}"
      nix_args=("${args[@]:1}")
      ;;
    *)
      nix_args=("${args[@]}")
      ;;
  esac
fi

# Remove leading "--" separator from nix_args (not needed for rebuild commands)
if [[ "${nix_args[0]:-}" == "--" ]]; then
  nix_args=("${nix_args[@]:1}")
fi

if [[ "$(uname -s)" == "Darwin" ]]; then
  darwin_action="$action"
  case "$action" in
    switch)
      darwin_action="switch"
      ;;
    test)
      darwin_action="check"
      ;;
    boot)
      echo "Darwin does not support 'boot' via darwin-rebuild." >&2
      exit 1
      ;;
  esac

  exec sudo -H nix run nix-darwin/master#darwin-rebuild -- \
    "$darwin_action" --flake "${flake_root}#${target_host}" --impure "${nix_args[@]}"
fi

build_attr="${flake_root}#nixosConfigurations.${target_host}.config.system.build.toplevel"
result_link="${flake_root}/result-rswitch-${target_host}"

sudo nix build "$build_attr" --impure -o "$result_link" "${nix_args[@]}"
exec sudo "$result_link/bin/switch-to-configuration" "$action"
